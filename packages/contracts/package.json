{
  "name": "@scrollstack/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": ["dist", "schema", "src/generated"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema/*": "./schema/*"
  },
  "scripts": {
    "generate:schemas": "uv run --project ../../backend python ../../backend/scripts/export_contracts.py",
    "generate:types": "node scripts/generate.mjs",
    "generate": "npm run generate:schemas && npm run generate:types",
    "check:generated": "uv run --project ../../backend python ../../backend/scripts/export_contracts.py --check && node scripts/generate.mjs --check",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "8.18.0",
    "ajv-formats": "3.0.1"
  },
  "devDependencies": {
    "@types/node": "22.15.30",
    "json-schema-to-typescript": "15.0.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
