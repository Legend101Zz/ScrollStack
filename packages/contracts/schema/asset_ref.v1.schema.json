{
  "$defs": {
    "ModelReceipt": {
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "minimum": 1,
          "title": "Attempt",
          "type": "integer"
        },
        "cost_usd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Usd"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "input_artifact_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 1000,
          "title": "Input Artifact Ids",
          "type": "array"
        },
        "input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "latency_ms": {
          "minimum": 0,
          "title": "Latency Ms",
          "type": "integer"
        },
        "model": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "output_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "prompt_version": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Prompt Version",
          "type": "string"
        },
        "provider": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "purpose": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "skill_hashes": {
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Skill Hashes",
          "type": "array"
        }
      },
      "required": [
        "provider",
        "model",
        "purpose",
        "prompt_version",
        "latency_ms",
        "attempt",
        "created_at"
      ],
      "title": "ModelReceipt",
      "type": "object"
    }
  },
  "$id": "https://scrollstack.dev/contracts/asset_ref.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "asset_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Asset Id",
      "type": "string"
    },
    "asset_type": {
      "enum": [
        "character_sprite",
        "expression",
        "key_panel",
        "background",
        "audio",
        "caption_track"
      ],
      "title": "Asset Type",
      "type": "string"
    },
    "content_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "duration_ms": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Duration Ms"
    },
    "height": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Height"
    },
    "mime_type": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Mime Type",
      "type": "string"
    },
    "model_receipt": {
      "anyOf": [
        {
          "$ref": "#/$defs/ModelReceipt"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Project Id",
      "type": "string"
    },
    "storage_ref": {
      "maxLength": 500,
      "minLength": 1,
      "pattern": "^(?:storage://|public/)[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$",
      "title": "Storage Ref",
      "type": "string"
    },
    "width": {
      "anyOf": [
        {
          "exclusiveMinimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Width"
    }
  },
  "required": [
    "asset_id",
    "project_id",
    "asset_type",
    "content_hash",
    "storage_ref",
    "mime_type"
  ],
  "title": "AssetRef",
  "type": "object"
}
