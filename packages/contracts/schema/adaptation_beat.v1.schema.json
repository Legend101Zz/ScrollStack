{
  "$defs": {
    "CharacterIntent": {
      "additionalProperties": false,
      "properties": {
        "character_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Character Id",
          "type": "string"
        },
        "emotional_state": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Emotional State",
          "type": "string"
        },
        "intent": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Intent",
          "type": "string"
        }
      },
      "required": [
        "character_id",
        "intent",
        "emotional_state"
      ],
      "title": "CharacterIntent",
      "type": "object"
    },
    "SourceRef": {
      "additionalProperties": false,
      "properties": {
        "book_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Book Id",
          "type": "string"
        },
        "end_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Offset"
        },
        "page_end": {
          "minimum": 1,
          "title": "Page End",
          "type": "integer"
        },
        "page_start": {
          "minimum": 1,
          "title": "Page Start",
          "type": "integer"
        },
        "quote": {
          "anyOf": [
            {
              "maxLength": 2000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quote"
        },
        "source_unit_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Source Unit Id",
          "type": "string"
        },
        "start_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Offset"
        },
        "text_hash": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Text Hash",
          "type": "string"
        }
      },
      "required": [
        "book_id",
        "source_unit_id",
        "page_start",
        "page_end",
        "text_hash"
      ],
      "title": "SourceRef",
      "type": "object"
    }
  },
  "$id": "https://scrollstack.dev/contracts/adaptation_beat.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "beat_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Beat Id",
      "type": "string"
    },
    "book_essence": {
      "maxLength": 20000,
      "minLength": 1,
      "title": "Book Essence",
      "type": "string"
    },
    "character_intent": {
      "items": {
        "$ref": "#/$defs/CharacterIntent"
      },
      "maxItems": 64,
      "title": "Character Intent",
      "type": "array"
    },
    "confidence": {
      "maximum": 1,
      "minimum": 0,
      "title": "Confidence",
      "type": "number"
    },
    "dramatization": {
      "maxLength": 20000,
      "minLength": 1,
      "title": "Dramatization",
      "type": "string"
    },
    "may_compress": {
      "items": {
        "maxLength": 20000,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 128,
      "title": "May Compress",
      "type": "array"
    },
    "must_preserve": {
      "items": {
        "maxLength": 20000,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 128,
      "minItems": 1,
      "title": "Must Preserve",
      "type": "array"
    },
    "narrative_purpose": {
      "enum": [
        "hook",
        "setup",
        "conflict",
        "explanation",
        "reveal",
        "payoff",
        "cliffhanger"
      ],
      "title": "Narrative Purpose",
      "type": "string"
    },
    "required_fact_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 128,
      "title": "Required Fact Ids",
      "type": "array"
    },
    "sequence": {
      "minimum": 0,
      "title": "Sequence",
      "type": "integer"
    },
    "source_refs": {
      "items": {
        "$ref": "#/$defs/SourceRef"
      },
      "maxItems": 128,
      "minItems": 1,
      "title": "Source Refs",
      "type": "array"
    },
    "visual_intent": {
      "items": {
        "maxLength": 500,
        "minLength": 1,
        "type": "string"
      },
      "maxItems": 64,
      "minItems": 1,
      "title": "Visual Intent",
      "type": "array"
    }
  },
  "required": [
    "beat_id",
    "sequence",
    "source_refs",
    "narrative_purpose",
    "book_essence",
    "dramatization",
    "visual_intent",
    "must_preserve",
    "confidence"
  ],
  "title": "AdaptationBeat",
  "type": "object"
}
