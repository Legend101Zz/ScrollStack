{
  "$defs": {
    "JsonValue": {},
    "StageStatus": {
      "enum": [
        "queued",
        "running",
        "waiting_for_assets",
        "validating",
        "repairing",
        "succeeded",
        "retryable_failed",
        "terminal_failed",
        "cancelled",
        "superseded"
      ],
      "title": "StageStatus",
      "type": "string"
    }
  },
  "$id": "https://scrollstack.dev/contracts/stage_run.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "agent_session_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Agent Session Id"
    },
    "attempt": {
      "minimum": 1,
      "title": "Attempt",
      "type": "integer"
    },
    "ended_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ended At"
    },
    "error_code": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Code"
    },
    "error_detail": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Detail"
    },
    "input_artifact_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 1000,
      "title": "Input Artifact Ids",
      "type": "array"
    },
    "input_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Input Hash",
      "type": "string"
    },
    "output_artifact_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 1000,
      "title": "Output Artifact Ids",
      "type": "array"
    },
    "run_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "const": "stage-run.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "stage_name": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Stage Name",
      "type": "string"
    },
    "stage_run_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Stage Run Id",
      "type": "string"
    },
    "started_at": {
      "anyOf": [
        {
          "format": "date-time",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "$ref": "#/$defs/StageStatus"
    }
  },
  "required": [
    "schema_version",
    "stage_run_id",
    "run_id",
    "stage_name",
    "attempt",
    "status",
    "input_hash"
  ],
  "title": "StageRun",
  "type": "object"
}
