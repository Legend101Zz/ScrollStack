{
  "$defs": {
    "AdaptationBeat": {
      "additionalProperties": false,
      "properties": {
        "beat_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Beat Id",
          "type": "string"
        },
        "book_essence": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Book Essence",
          "type": "string"
        },
        "character_intent": {
          "items": {
            "$ref": "#/$defs/CharacterIntent"
          },
          "maxItems": 64,
          "title": "Character Intent",
          "type": "array"
        },
        "confidence": {
          "maximum": 1,
          "minimum": 0,
          "title": "Confidence",
          "type": "number"
        },
        "dramatization": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Dramatization",
          "type": "string"
        },
        "may_compress": {
          "items": {
            "maxLength": 20000,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 128,
          "title": "May Compress",
          "type": "array"
        },
        "must_preserve": {
          "items": {
            "maxLength": 20000,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 128,
          "minItems": 1,
          "title": "Must Preserve",
          "type": "array"
        },
        "narrative_purpose": {
          "enum": [
            "hook",
            "setup",
            "conflict",
            "explanation",
            "reveal",
            "payoff",
            "cliffhanger"
          ],
          "title": "Narrative Purpose",
          "type": "string"
        },
        "required_fact_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 128,
          "title": "Required Fact Ids",
          "type": "array"
        },
        "sequence": {
          "minimum": 0,
          "title": "Sequence",
          "type": "integer"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceRef"
          },
          "maxItems": 128,
          "minItems": 1,
          "title": "Source Refs",
          "type": "array"
        },
        "visual_intent": {
          "items": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 64,
          "minItems": 1,
          "title": "Visual Intent",
          "type": "array"
        }
      },
      "required": [
        "beat_id",
        "sequence",
        "source_refs",
        "narrative_purpose",
        "book_essence",
        "dramatization",
        "visual_intent",
        "must_preserve",
        "confidence"
      ],
      "title": "AdaptationBeat",
      "type": "object"
    },
    "CharacterIntent": {
      "additionalProperties": false,
      "properties": {
        "character_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Character Id",
          "type": "string"
        },
        "emotional_state": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Emotional State",
          "type": "string"
        },
        "intent": {
          "maxLength": 20000,
          "minLength": 1,
          "title": "Intent",
          "type": "string"
        }
      },
      "required": [
        "character_id",
        "intent",
        "emotional_state"
      ],
      "title": "CharacterIntent",
      "type": "object"
    },
    "CropHint": {
      "additionalProperties": false,
      "properties": {
        "box_pct": {
          "$ref": "#/$defs/LayoutBoxPct"
        },
        "crop_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Crop Id",
          "type": "string"
        },
        "subject": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Subject",
          "type": "string"
        }
      },
      "required": [
        "crop_id",
        "box_pct",
        "subject"
      ],
      "title": "CropHint",
      "type": "object"
    },
    "DialogueLine": {
      "additionalProperties": false,
      "properties": {
        "delivery": {
          "anyOf": [
            {
              "maxLength": 500,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delivery"
        },
        "speaker_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Speaker Id",
          "type": "string"
        },
        "text": {
          "maxLength": 1000,
          "minLength": 1,
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "speaker_id",
        "text"
      ],
      "title": "DialogueLine",
      "type": "object"
    },
    "LayoutBoxPct": {
      "additionalProperties": false,
      "properties": {
        "height_pct": {
          "exclusiveMinimum": 0,
          "maximum": 100,
          "title": "Height Pct",
          "type": "number"
        },
        "width_pct": {
          "exclusiveMinimum": 0,
          "maximum": 100,
          "title": "Width Pct",
          "type": "number"
        },
        "x_pct": {
          "maximum": 100,
          "minimum": 0,
          "title": "X Pct",
          "type": "number"
        },
        "y_pct": {
          "maximum": 100,
          "minimum": 0,
          "title": "Y Pct",
          "type": "number"
        }
      },
      "required": [
        "x_pct",
        "y_pct",
        "width_pct",
        "height_pct"
      ],
      "title": "LayoutBoxPct",
      "type": "object"
    },
    "ManifestPanel": {
      "additionalProperties": false,
      "properties": {
        "beat_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 32,
          "minItems": 1,
          "title": "Beat Ids",
          "type": "array"
        },
        "crop_hints": {
          "items": {
            "$ref": "#/$defs/CropHint"
          },
          "maxItems": 16,
          "title": "Crop Hints",
          "type": "array"
        },
        "dialogue": {
          "items": {
            "$ref": "#/$defs/DialogueLine"
          },
          "maxItems": 16,
          "title": "Dialogue",
          "type": "array"
        },
        "emotional_tone": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Emotional Tone",
          "type": "string"
        },
        "narration": {
          "items": {
            "maxLength": 1000,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 8,
          "title": "Narration",
          "type": "array"
        },
        "page_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Page Id",
          "type": "string"
        },
        "panel_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Panel Id",
          "type": "string"
        },
        "panel_type": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Panel Type",
          "type": "string"
        },
        "sequence": {
          "minimum": 0,
          "title": "Sequence",
          "type": "integer"
        },
        "source_refs": {
          "items": {
            "$ref": "#/$defs/SourceRef"
          },
          "maxItems": 128,
          "minItems": 1,
          "title": "Source Refs",
          "type": "array"
        },
        "visual_asset_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 32,
          "title": "Visual Asset Ids",
          "type": "array"
        }
      },
      "required": [
        "panel_id",
        "page_id",
        "sequence",
        "beat_ids",
        "panel_type",
        "emotional_tone",
        "source_refs"
      ],
      "title": "ManifestPanel",
      "type": "object"
    },
    "SourceRef": {
      "additionalProperties": false,
      "properties": {
        "book_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Book Id",
          "type": "string"
        },
        "end_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Offset"
        },
        "page_end": {
          "minimum": 1,
          "title": "Page End",
          "type": "integer"
        },
        "page_start": {
          "minimum": 1,
          "title": "Page Start",
          "type": "integer"
        },
        "quote": {
          "anyOf": [
            {
              "maxLength": 2000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quote"
        },
        "source_unit_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Source Unit Id",
          "type": "string"
        },
        "start_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Offset"
        },
        "text_hash": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Text Hash",
          "type": "string"
        }
      },
      "required": [
        "book_id",
        "source_unit_id",
        "page_start",
        "page_end",
        "text_hash"
      ],
      "title": "SourceRef",
      "type": "object"
    }
  },
  "$id": "https://scrollstack.dev/contracts/manga_manifest.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "art_direction_artifact_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Art Direction Artifact Id",
      "type": "string"
    },
    "beats": {
      "items": {
        "$ref": "#/$defs/AdaptationBeat"
      },
      "maxItems": 1000,
      "minItems": 1,
      "title": "Beats",
      "type": "array"
    },
    "character_asset_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 1000,
      "title": "Character Asset Ids",
      "type": "array"
    },
    "content_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "manga_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Manga Id",
      "type": "string"
    },
    "memory_version": {
      "minimum": 0,
      "title": "Memory Version",
      "type": "integer"
    },
    "panels": {
      "items": {
        "$ref": "#/$defs/ManifestPanel"
      },
      "maxItems": 10000,
      "minItems": 1,
      "title": "Panels",
      "type": "array"
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Project Id",
      "type": "string"
    },
    "rendered_page_artifact_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 1000,
      "minItems": 1,
      "title": "Rendered Page Artifact Ids",
      "type": "array"
    },
    "schema_version": {
      "const": "manga-manifest.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "scope_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Scope Id",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "manga_id",
    "project_id",
    "scope_id",
    "memory_version",
    "rendered_page_artifact_ids",
    "beats",
    "panels",
    "art_direction_artifact_id",
    "content_hash"
  ],
  "title": "MangaManifest",
  "type": "object"
}
