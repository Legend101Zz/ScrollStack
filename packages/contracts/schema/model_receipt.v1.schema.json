{
  "$id": "https://scrollstack.dev/contracts/model_receipt.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attempt": {
      "minimum": 1,
      "title": "Attempt",
      "type": "integer"
    },
    "cost_usd": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "number"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Cost Usd"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "input_artifact_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 1000,
      "title": "Input Artifact Ids",
      "type": "array"
    },
    "input_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Input Tokens"
    },
    "latency_ms": {
      "minimum": 0,
      "title": "Latency Ms",
      "type": "integer"
    },
    "model": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Model",
      "type": "string"
    },
    "output_tokens": {
      "anyOf": [
        {
          "minimum": 0,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Tokens"
    },
    "prompt_version": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Prompt Version",
      "type": "string"
    },
    "provider": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Provider",
      "type": "string"
    },
    "purpose": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Purpose",
      "type": "string"
    },
    "skill_hashes": {
      "items": {
        "pattern": "^[a-f0-9]{64}$",
        "type": "string"
      },
      "maxItems": 64,
      "title": "Skill Hashes",
      "type": "array"
    }
  },
  "required": [
    "provider",
    "model",
    "purpose",
    "prompt_version",
    "latency_ms",
    "attempt",
    "created_at"
  ],
  "title": "ModelReceipt",
  "type": "object"
}
