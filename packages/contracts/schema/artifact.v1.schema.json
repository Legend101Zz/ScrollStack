{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "context_pack",
        "adaptation_beat_set",
        "manga_plan",
        "asset_request_set",
        "manga_script",
        "storyboard",
        "page_composition",
        "rendered_page_set",
        "manga_manifest",
        "reel_spec",
        "render_receipt",
        "memory_delta"
      ],
      "title": "ArtifactKind",
      "type": "string"
    },
    "JsonValue": {},
    "ModelReceipt": {
      "additionalProperties": false,
      "properties": {
        "attempt": {
          "minimum": 1,
          "title": "Attempt",
          "type": "integer"
        },
        "cost_usd": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Cost Usd"
        },
        "created_at": {
          "format": "date-time",
          "title": "Created At",
          "type": "string"
        },
        "input_artifact_ids": {
          "items": {
            "maxLength": 128,
            "minLength": 1,
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
            "type": "string"
          },
          "maxItems": 1000,
          "title": "Input Artifact Ids",
          "type": "array"
        },
        "input_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Input Tokens"
        },
        "latency_ms": {
          "minimum": 0,
          "title": "Latency Ms",
          "type": "integer"
        },
        "model": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "output_tokens": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Output Tokens"
        },
        "prompt_version": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Prompt Version",
          "type": "string"
        },
        "provider": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Provider",
          "type": "string"
        },
        "purpose": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Purpose",
          "type": "string"
        },
        "skill_hashes": {
          "items": {
            "pattern": "^[a-f0-9]{64}$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Skill Hashes",
          "type": "array"
        }
      },
      "required": [
        "provider",
        "model",
        "purpose",
        "prompt_version",
        "latency_ms",
        "attempt",
        "created_at"
      ],
      "title": "ModelReceipt",
      "type": "object"
    },
    "SourceRef": {
      "additionalProperties": false,
      "properties": {
        "book_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Book Id",
          "type": "string"
        },
        "end_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "End Offset"
        },
        "page_end": {
          "minimum": 1,
          "title": "Page End",
          "type": "integer"
        },
        "page_start": {
          "minimum": 1,
          "title": "Page Start",
          "type": "integer"
        },
        "quote": {
          "anyOf": [
            {
              "maxLength": 2000,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Quote"
        },
        "source_unit_id": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Source Unit Id",
          "type": "string"
        },
        "start_offset": {
          "anyOf": [
            {
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Start Offset"
        },
        "text_hash": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Text Hash",
          "type": "string"
        }
      },
      "required": [
        "book_id",
        "source_unit_id",
        "page_start",
        "page_end",
        "text_hash"
      ],
      "title": "SourceRef",
      "type": "object"
    },
    "ValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Code",
          "type": "string"
        },
        "message": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "path": {
          "anyOf": [
            {
              "maxLength": 500,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Path"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "title": "ValidationIssue",
      "type": "object"
    },
    "ValidationReport": {
      "additionalProperties": false,
      "properties": {
        "issues": {
          "items": {
            "$ref": "#/$defs/ValidationIssue"
          },
          "maxItems": 1000,
          "title": "Issues",
          "type": "array"
        },
        "passed": {
          "title": "Passed",
          "type": "boolean"
        },
        "validator_version": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Validator Version",
          "type": "string"
        }
      },
      "required": [
        "passed",
        "validator_version"
      ],
      "title": "ValidationReport",
      "type": "object"
    }
  },
  "$id": "https://scrollstack.dev/contracts/artifact.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Artifact Id",
      "type": "string"
    },
    "content": {
      "anyOf": [
        {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Content"
    },
    "content_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Content Hash",
      "type": "string"
    },
    "created_at": {
      "format": "date-time",
      "title": "Created At",
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/ArtifactKind"
    },
    "model_receipt": {
      "anyOf": [
        {
          "$ref": "#/$defs/ModelReceipt"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "parent_artifact_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 1,
        "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
        "type": "string"
      },
      "maxItems": 1000,
      "title": "Parent Artifact Ids",
      "type": "array"
    },
    "project_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Project Id",
      "type": "string"
    },
    "run_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Run Id",
      "type": "string"
    },
    "schema_version": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Schema Version",
      "type": "string"
    },
    "source_refs": {
      "items": {
        "$ref": "#/$defs/SourceRef"
      },
      "maxItems": 10000,
      "title": "Source Refs",
      "type": "array"
    },
    "storage_ref": {
      "anyOf": [
        {
          "maxLength": 500,
          "minLength": 1,
          "pattern": "^(?:storage://|public/)[A-Za-z0-9][A-Za-z0-9._-]*(?:/[A-Za-z0-9][A-Za-z0-9._-]*)*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Storage Ref"
    },
    "validation_report": {
      "$ref": "#/$defs/ValidationReport"
    },
    "validation_status": {
      "enum": [
        "pending",
        "valid",
        "invalid",
        "accepted",
        "rejected",
        "superseded"
      ],
      "title": "Validation Status",
      "type": "string"
    }
  },
  "required": [
    "artifact_id",
    "project_id",
    "run_id",
    "kind",
    "schema_version",
    "content_hash",
    "validation_status",
    "validation_report",
    "created_at"
  ],
  "title": "Artifact",
  "type": "object"
}
