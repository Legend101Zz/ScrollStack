{
  "$defs": {
    "PageValidationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "maxLength": 128,
          "minLength": 1,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
          "title": "Code",
          "type": "string"
        },
        "message": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "node_id": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Node Id"
        },
        "path": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Path",
          "type": "string"
        },
        "severity": {
          "enum": [
            "error",
            "warning",
            "info"
          ],
          "title": "Severity",
          "type": "string"
        }
      },
      "required": [
        "code",
        "severity",
        "message",
        "path"
      ],
      "title": "PageValidationIssue",
      "type": "object"
    }
  },
  "$id": "https://scrollstack.dev/contracts/page_validation_report.v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "candidate_artifact_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Candidate Artifact Id",
      "type": "string"
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/PageValidationIssue"
      },
      "maxItems": 1000,
      "title": "Issues",
      "type": "array"
    },
    "passed": {
      "title": "Passed",
      "type": "boolean"
    },
    "report_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$",
      "title": "Report Id",
      "type": "string"
    },
    "schema_version": {
      "const": "page-validation-report.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "validator_version": {
      "maxLength": 500,
      "minLength": 1,
      "title": "Validator Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "report_id",
    "candidate_artifact_id",
    "validator_version",
    "passed"
  ],
  "title": "PageValidationReport",
  "type": "object"
}
