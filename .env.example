MONGODB_URI=mongodb://mongo:27017/scrollstack
REDIS_URL=redis://redis:6379/0
MEDIA_STORAGE_BACKEND=local
MEDIA_ROOT=/data/media

AGENT_WORKER_URL=http://agent_worker:8788
AGENT_WORKER_TOKEN=replace-with-a-long-random-token
AGENT_PROVIDER=minimax
AGENT_MODEL=MiniMax-M2.7-highspeed
AGENT_MODEL_API_KEY_ENV=MINIMAX_API_KEY
AGENT_MAX_CONCURRENCY=2
AGENT_SESSION_DIR=/data/agent-sessions
DOMAIN_TOOL_BROKER_URL=http://backend:8000
DOMAIN_TOOL_BROKER_TOKEN=replace-with-a-third-long-random-token

REEL_RENDER_WORKER_URL=http://reel_render_worker:4200
REEL_RENDER_WORKER_TOKEN=replace-with-a-different-long-random-token
REEL_RENDER_CONCURRENCY=1

OPENAI_API_KEY=
MINIMAX_API_KEY=
OPENROUTER_API_KEY=
IMAGE_MODEL=google/gemini-2.5-flash-image

AGENTIC_MANGA_PIPELINE_V1=true
REELS_ENABLED=false
REEL_EXPORT_ENABLED=false
ALLOW_LLM_CODEGEN=false

NEXT_PUBLIC_API_URL=http://localhost:8000
INTERNAL_API_URL=http://backend:8000
